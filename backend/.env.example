# Gemini API (Google AI Studio) - Recomendado para desarrollo
# Obtén tu API key en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# Vertex AI (Opcional - Solo para producción)
# GCP_PROJECT_ID=your-project-id
# GCP_LOCATION=us-central1
# VERTEX_AI_MODEL=gemini-1.5-pro
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# General
CORS_ORIGINS=http://localhost:3000,https://your-domain.com
USE_MOCK=false

# Logging
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Firebase Admin SDK (para autenticación)
# Opción 1: Usar archivo de service account (Recomendado para producción)
# FIREBASE_SERVICE_ACCOUNT_KEY=./firebase-service-account.json
# Opción 2: Dejar vacío para usar credenciales por defecto (desarrollo local)

# Firebase Storage (para almacenamiento de ZIPs)
# El bucket se configura automáticamente desde Firebase
# Tier gratuito: 5GB almacenamiento, 1GB/día descarga
FIREBASE_STORAGE_BUCKET=vibe-architect-676ae.firebasestorage.app
