---
/**
 * Footer Component
 * 
 * Application footer with links and information.
 */

const currentYear = new Date().getFullYear();
---

<footer class="border-t border-gray-200 bg-gray-50">
  <div class="container mx-auto px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <!-- Brand -->
      <div class="col-span-1">
        <div class="flex items-center gap-2 mb-4">
          <div class="h-8 w-8 rounded-lg bg-indigo-500 flex items-center justify-center">
            <span class="text-white font-bold text-lg">A</span>
          </div>
          <span class="font-semibold text-lg">My App</span>
        </div>
        <p class="text-sm text-gray-600">
          Building amazing experiences with modern web technologies.
        </p>
      </div>

      <!-- Product -->
      <div>
        <h3 class="font-semibold text-sm text-gray-900 mb-4">Product</h3>
        <ul class="space-y-3">
          <li><a href="/features" class="text-sm text-gray-600 hover:text-indigo-600 transition-colors">Features</a></li>
          <li><a href="/pricing" class="text-sm text-gray-600 hover:text-indigo-600 transition-colors">Pricing</a></li>
          <li><a href="/docs" class="text-sm text-gray-600 hover:text-indigo-600 transition-colors">Documentation</a></li>
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="font-semibold text-sm text-gray-900 mb-4">Company</h3>
        <ul class="space-y-3">
          <li><a href="/about" class="text-sm text-gray-600 hover:text-indigo-600 transition-colors">About</a></li>
          <li><a href="/blog" class="text-sm text-gray-600 hover:text-indigo-600 transition-colors">Blog</a></li>
          <li><a href="/contact" class="text-sm text-gray-600 hover:text-indigo-600 transition-colors">Contact</a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h3 class="font-semibold text-sm text-gray-900 mb-4">Legal</h3>
        <ul class="space-y-3">
          <li><a href="/privacy" class="text-sm text-gray-600 hover:text-indigo-600 transition-colors">Privacy</a></li>
          <li><a href="/terms" class="text-sm text-gray-600 hover:text-indigo-600 transition-colors">Terms</a></li>
          <li><a href="/cookies" class="text-sm text-gray-600 hover:text-indigo-600 transition-colors">Cookies</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom -->
    <div class="mt-12 pt-8 border-t border-gray-200">
      <p class="text-sm text-gray-600 text-center">
        © {currentYear} My App. All rights reserved.
      </p>
    </div>
  </div>
</footer>
