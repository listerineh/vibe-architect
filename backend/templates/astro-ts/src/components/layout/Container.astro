---
/**
 * Container Component
 * 
 * Responsive container wrapper with max-width and padding.
 * Centers content and provides consistent spacing.
 */

interface Props {
  size?: 'sm' | 'md' | 'lg' | 'xl' | 'full';
  class?: string;
}

const { size = 'lg', class: className = '' } = Astro.props;

const sizeClasses = {
  sm: 'max-w-3xl',
  md: 'max-w-5xl',
  lg: 'max-w-7xl',
  xl: 'max-w-screen-2xl',
  full: 'max-w-full',
};

const classes = `container mx-auto px-4 sm:px-6 lg:px-8 ${sizeClasses[size]} ${className}`;
---

<div class={classes}>
  <slot />
</div>
