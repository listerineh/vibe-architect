---
/**
 * Base Layout
 * 
 * Main layout wrapper for all pages.
 * Includes HTML structure, meta tags, and global styles.
 */

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'A modern Astro application' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
